PORT=8000
HOST=0.0.0.0

# API Security
API_KEY=your_super_secret_api_key_here

# Email Verification Configuration
# HELO_HOST should be the FQDN of the server running this container (e.g. mail.yourdomain.com)
HELO_HOST=mail.example.com
# MAIL_FROM should be a valid email address authorized to send from your server's IP
MAIL_FROM=verify@example.com
# Time to wait (in seconds) for SMTP connections. 
# 15 is recommended to bypass tarpitting mechanisms like Postscreen.
SMTP_TIMEOUT=15
